#!/usr/bin/env python3
"""
Protein Design Research Agent - Web Interface
Interactive frontend for querying papers and databases
"""
import os
import streamlit as st
import sys
import uuid
from pathlib import Path
import streamlit.components.v1 as components

# Add project to path
sys.path.append(str(Path(__file__).parent))

from agent.rag.enhanced_paper_rag import LocalPDFRAG
from agent. import ProteinDesignAgent

# Page config
st.set_page_config(
    page_title="Protein Design Research Agent",
    page_icon="🧬",
    layout="wide",
    initial_sidebar_state="collapsed"
)

# Custom CSS
st.markdown("""
<style>
    .main-header {
        font-size: 2.5rem;
        font-weight: 700;
        color: #1f77b4;
        margin-bottom: 0.5rem;
        text-align: center;
    }
    .sub-header {
        font-size: 1.1rem;
        color: #666;
        margin-bottom: 2rem;
        text-align: center;
    }
    .stChatMessage {
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
    }
</style>
""", unsafe_allow_html=True)

# Initialize session state
if 'rag' not in st.session_state:
    with st.spinner("🔄 Loading RAG system..."):
        st.session_state.rag = LocalPDFRAG(
            pdf_directory="./data/papers",
            vd_persist_directory="./data/chroma_db",
            bm25_persist_directory="./data/bm25_index",
        )
        st.session_state.stats = st.session_state.rag.get_statistics()

if 'agent' not in st.session_state:
    with st.spinner("🔄 Loading Zenmux agent..."):
        st.session_state.agent = ProteinDesignAgent(
            rag_instance=st.session_state.rag,
            model=os.getenv("LLM_MODEL", "google/gemini-2.5-flash-lite"),
        )

if 'messages' not in st.session_state:
    st.session_state.messages = []

if 'thread_id' not in st.session_state:
    st.session_state.thread_id = str(uuid.uuid4())

# Helper function to display rich content
def display_rich_content(metadata, use_rag):
    # Display PDB Structures (3Dmol.js)
    if metadata.get('pdb_hits'):
        with st.expander("🧬 3D Structure Viewer (PDB)", expanded=True):
            hits = metadata['pdb_hits']
            # Deduplicate by ID
            seen = set()
            unique_hits = []
            for h in hits:
                if h.get('pdb_id') and h.get('pdb_id') not in seen:
                    unique_hits.append(h)
                    seen.add(h.get('pdb_id'))
            
            # Show selector if multiple
            selected_pdb = unique_hits[0]
            if len(unique_hits) > 1:
                selected_pdb_id = st.selectbox(
                    "Select Structure to View", 
                    options=[h['pdb_id'] for h in unique_hits],
                    format_func=lambda x: f"{x} - {[h['title'] for h in unique_hits if h['pdb_id'] == x][0]}"
                )
                selected_pdb = next(h for h in unique_hits if h['pdb_id'] == selected_pdb_id)
            
            # Layout: Left (Structure) | Right (Info)
            col1, col2 = st.columns([2, 1])
            
            with col1:
                # Render 3Dmol.js
                pdb_id = selected_pdb['pdb_id']
                html_code = f"""
                <!DOCTYPE html>
                <html>
                <head>
                  <script src="https://3Dmol.org/build/3Dmol-min.js"></script>
                  <style>
                    body, html {{ margin: 0; padding: 0; height: 100%; width: 100%; }}
                    #container-{pdb_id} {{ height: 400px; width: 100%; position: relative; }}
                  </style>
                </head>
                <body>
                  <div id="container-{pdb_id}"></div>
                  <script>
                    document.addEventListener('DOMContentLoaded', function() {{
                      let element = document.getElementById("container-{pdb_id}");
                      let config = {{ backgroundColor: "white" }};
                      let viewer = $3Dmol.createViewer(element, config);
                      
                      let pdbId = "{pdb_id}";
                      
                      $3Dmol.download("pdb:" + pdbId, viewer, {{}}, function() {{
                        viewer.setStyle({{cartoon: {{color: "spectrum"}}}});
                        viewer.zoomTo();
                        viewer.render();
                      }});
                    }});
                  </script>
                </body>
                </html>
                """
                components.html(html_code, height=400)
                st.caption("Interact with mouse: Rotate (Left Click), Zoom (Scroll), Pan (Right Click)")

            with col2:
                st.markdown(f"### 🧬 {selected_pdb['pdb_id']} | {selected_pdb['pdb_id'].lower()}")
                st.markdown(f"**{selected_pdb.get('title', 'Unknown Title')}**")
                
                if selected_pdb.get('doi'):
                    st.markdown(f"**PDB DOI**: [https://doi.org/{selected_pdb['doi']}](https://doi.org/{selected_pdb['doi']})")
                
                if selected_pdb.get('classification'):
                    st.markdown(f"**Classification**: {selected_pdb['classification']}")
                
                if selected_pdb.get('organism'):
                    orgs = ", ".join(selected_pdb['organism'])
                    st.markdown(f"**Organism(s)**: {orgs}")
                    
                if selected_pdb.get('expression_system'):
                    hosts = ", ".join(selected_pdb['expression_system'])
                    st.markdown(f"**Expression System**: {hosts}")
                    
                if selected_pdb.get('mutation'):
                    st.markdown(f"**Mutation(s)**: {selected_pdb['mutation']}")
                
                st.markdown("---")
                
                if selected_pdb.get('polymer_composition'):
                    st.markdown(f"**Polymer Composition**: {selected_pdb['polymer_composition']}")
                
                if selected_pdb.get('resolution'):
                    st.markdown(f"**Resolution**: {selected_pdb['resolution']} Å")
                
                if selected_pdb.get('method'):
                    st.markdown(f"**Method**: {selected_pdb['method']}")
                
                if selected_pdb.get('deposition_date'):
                    st.markdown(f"**Deposited**: {selected_pdb['deposition_date'][:10]}")
                
                st.markdown(f"[View on RCSB PDB ↗](https://www.rcsb.org/structure/{selected_pdb['pdb_id']})")

            st.divider()

    # Display UniProt Hits
    if metadata.get('uniprot_hits'):
        with st.expander("🧬 UniProt Proteins Found", expanded=False):
            hits = metadata['uniprot_hits']
            # Deduplicate by ID
            seen = set()
            unique_hits = []
            for h in hits:
                if h.get('uniprot_id') not in seen:
                    unique_hits.append(h)
                    seen.add(h.get('uniprot_id'))
            
            for hit in unique_hits:
                st.markdown(f"**{hit.get('protein_name', 'Unknown')}**")
                st.caption(f"Organism: {hit.get('organism', 'Unknown')} | ID: {hit.get('uniprot_id')}")
                if hit.get('length'):
                    st.caption(f"Length: {hit.get('length')} aa")
                
                if hit.get('uniprot_id'):
                    url = f"https://www.uniprot.org/uniprotkb/{hit['uniprot_id']}/entry"
                    st.markdown(f"[View on UniProt ↗]({url})")
                st.divider()

    # Display sources
    if use_rag and metadata.get('sources'):
        with st.expander("📚 Sources Used", expanded=False):
            # Handle case where sources exist but retrieved_docs is empty (Tools Only mode)
            has_docs = len(metadata.get('retrieved_docs', [])) > 0
            
            for i, source in enumerate(metadata['sources'], 1):
                st.markdown(f"**{i}. {source}**")
                if has_docs and i <= len(metadata['retrieved_docs']):
                    doc = metadata['retrieved_docs'][i-1]
                    st.caption(f"Score: {doc.get('score', 0):.4f} | Section: {doc.get('section', 'General')}")
                    st.text(doc['content'][:300] + "..." if len(doc['content']) > 300 else doc['content'])
                else:
                    st.caption("Source provided by external tool/database.")
                st.divider()

    # Metadata
    with st.expander("🔧 Query Details", expanded=False):
        st.json({
            "model": metadata.get('model', 'unknown'),
            "chunks_retrieved": metadata.get('retrieved_chunks', 0),
        })

# Sidebar
with st.sidebar:
    st.header("⚙️ Settings")
    
    top_k = st.slider(
        "Retrieval Sources",
        min_value=1,
        max_value=10,
        value=5
    )
    
    use_rag = st.checkbox(
        "Use RAG",
        value=True
    )
    
    st.divider()
    
    # Metrics
    stats = st.session_state.stats
    with st.expander("📊 System Status"):
        col1, col2 = st.columns(2)
        with col1:
            st.metric("Papers", stats['total_papers'])
        with col2:
            st.metric("Chunks", stats['total_chunks'])
            
    # Indexed Papers List
    with st.expander("📚 Indexed Papers"):
        if stats['total_papers'] == 0:
            st.warning("No papers indexed yet")
        else:
            for i, (filename, info) in enumerate(stats['papers'].items(), 1):
                st.markdown(f"**{i}. {info['title']}**")
                st.caption(f"{info['author']} ({info['chunks']} chunks)")

    with st.expander("ℹ️ About"):
        st.markdown("""
        **Protein Design Research Agent**
        
        Powered by Zenmux & ChromaDB.
        Helps protein engineers find relevant research and design strategies.
        """)

# Main Chat Interface
col1, col2 = st.columns([6, 1])
with col1:
    st.markdown('<div class="main-header">🧬 Protein Design Research Agent</div>', unsafe_allow_html=True)
with col2:
    if st.button("➕ New Chat", type="primary", use_container_width=True):
        st.session_state.messages = []
        st.session_state.thread_id = str(uuid.uuid4())
        st.rerun()

# Display chat history
for message in st.session_state.messages:
    with st.chat_message(message["role"]):
        st.markdown(message["content"])
        if message["role"] == "assistant" and "metadata" in message:
            display_rich_content(message["metadata"], use_rag)

# Chat Input
if prompt := st.chat_input("Ask a question about enzyme engineering..."):
    # Add user message
    st.session_state.messages.append({"role": "user", "content": prompt})
    with st.chat_message("user"):
        st.markdown(prompt)

    # Generate response
    with st.chat_message("assistant"):
        message_placeholder = st.empty()
        status_placeholder = st.empty()
        full_answer = ""
        result_metadata = None
        
        try:
            # Stream response
            for chunk in st.session_state.agent.query_stream(
                question=prompt,
                top_k=top_k,
                use_rag=use_rag,
                thread_id=st.session_state.thread_id
            ):
                if chunk["type"] == "status":
                    status_placeholder.caption(f"🤖 {chunk['content']}...")
                elif chunk["type"] == "answer_chunk":
                    full_answer += chunk["content"]
                    message_placeholder.markdown(full_answer + "▌")
                elif chunk["type"] == "result":
                    result_metadata = chunk["content"]
            
            # Finalize display
            status_placeholder.empty()
            message_placeholder.markdown(full_answer)
            
            if result_metadata:
                display_rich_content(result_metadata, use_rag)
                
                # Add assistant message to history
                st.session_state.messages.append({
                    "role": "assistant", 
                    "content": full_answer,
                    "metadata": result_metadata
                })
            else:
                 # Fallback if no metadata
                 st.session_state.messages.append({
                    "role": "assistant", 
                    "content": full_answer
                })

        except Exception as e:
            status_placeholder.error(f"❌ Error: {str(e)}")
            st.exception(e)
